# Database (Neon Postgres with pgvector)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# LLM Providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Optional — only set if you want to add OpenAI calls back later
OPENAI_API_KEY=

# Google Cloud TTS (new dedicated project)
GOOGLE_TTS_API_KEY=

# Ingestion (Codex direct webhook + sync agent)
COS_INGEST_TOKEN=

# Vercel Cron (set automatically by Vercel; falsey locally)
CRON_SECRET=

# Hard daily LLM spend cap in USD. Optional — budget guard defaults to 50 if unset.
COS_DAILY_USD_CAP=50

# Vercel "Protection Bypass for Automation" secret. Required once Vercel Password
# Protection is enabled so machine callers (Codex ingest connectors, the sync agent,
# Inngest) can reach the deployment. Generate it in Vercel → Project → Settings →
# Deployment Protection → Protection Bypass for Automation, then set the SAME value here
# and in the ingest connector / sync-agent environment.
VERCEL_AUTOMATION_BYPASS_SECRET=

# Vercel Blob storage (audio briefings)
BLOB_READ_WRITE_TOKEN=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Optional: Sentry
SENTRY_DSN=

# Optional: app metadata
NEXT_PUBLIC_APP_NAME=Chief of Staff
