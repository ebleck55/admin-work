# Database (Neon Postgres with pgvector)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# LLM Providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Optional — only set if you want to add OpenAI calls back later
OPENAI_API_KEY=

# Google Cloud TTS (new dedicated project)
GOOGLE_TTS_API_KEY=

# Ingestion (Codex direct webhook + sync agent)
COS_INGEST_TOKEN=

# Vercel Cron (set automatically by Vercel; falsey locally)
CRON_SECRET=

# Hard daily LLM spend cap in USD. Optional — budget guard defaults to 50 if unset.
COS_DAILY_USD_CAP=50

# App login gate (single user). REQUIRED in production.
#   COS_APP_PASSWORD   — the password you type to sign in. Use something long.
#   COS_SESSION_SECRET — signs the session cookie. Generate with: openssl rand -base64 32
COS_APP_PASSWORD=
COS_SESSION_SECRET=

# Vercel Blob storage (audio briefings)
BLOB_READ_WRITE_TOKEN=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Optional: Sentry
SENTRY_DSN=

# Optional: app metadata
NEXT_PUBLIC_APP_NAME=Chief of Staff
